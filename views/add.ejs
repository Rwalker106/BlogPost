  <head>

    <title>Add Blog Post</title>
  </head>

    <main>
      <div class="container mt-4">
        <h2 class="mb-4">Add a New Blog Post</h2>
        <form action="/add" method="POST">
          <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" class="form-control" id="title" name="title" required>
          </div>
          <div class="mb-3">
            <label for="content" class="form-label">Content</label>
            <textarea class="form-control" id="content" name="content" rows="5" required></textarea>
          </div>
          <div class="mb-3">
            <label for="author" class="form-label">Author</label>
            <input type="text" class="form-control" id="author" name="author" required>
          </div>
          <div class="mb-3">
            <label for="picture" class="form-label">Picture</label>
            <input type="url" class="form-control" id="picture" name="picture" 
                placeholder="https://example.com/image.jpg"
                pattern="https?://.*\.(jpg|jpeg|png|gif|webp)"
                required>
              <% if (typeof post !== 'undefined' && post.picture) { %>
                  <img id="preview" src="<%= post.picture %>" class="img-fluid rounded mt-2" style="max-height: 200px;">
                  <% } else { %>
                  <img id="preview" class="img-fluid rounded mt-2" style="max-height: 200px; display:none;">
              <% } %>
          </div>

          <button type="submit" class="btn btn-submit btn-md rounded-pill" role="button" title="Add Post">Submit</button>
        </form>
      </div>
    </main>
    <script>
       const input = document.getElementById("picture");
        const preview = document.getElementById("preview");

      input.addEventListener("input", () => {preview.src = input.value;
});
</script>
