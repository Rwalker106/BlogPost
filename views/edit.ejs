
    <main>
      <div class="container mt-4">
        <h2 class="mb-4 text-center">Edit Post</h2>
        <form action="/edit/<%= post.id %>" method="POST" data-id="<%= post.id %>" onsubmit="return confirmEdit(this.dataset.id)">
          <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input
              type="text"
              class="form-control"
              id="title"
              name="title"
              value="<%= post.title %>"
              required
            />
          </div>
          <div class="mb-3">
            <label for="content" class="form-label">Content</label>
            <textarea
              class="form-control"
              id="content"
              name="content"
              rows="5"
              required
            ><%= post.content %></textarea>
          </div>
          <div class="mb-3">
            <label for="author" class="form-label">Author</label>
            <input
              type="text"
              class="form-control"
              id="author"
              name="author"
              value="<%= post.author %>"
              required>
          </div>
          <div class="mb-3">
            <label for="picture" class="form-label">Picture URL</label>
            <input
              type="url"
              class="form-control"
              id="picture"
              name="picture"
              value="<%= post.picture %>"
            />
          </div>
          <div class="d-flex gap-3 mt-5 align-items-stretch">
            <button type="submit" class="btn btn-dark mb-2 save_changes" role="button" title="Modify Post">Save Changes</button>
        </form>

            <form action="/delete/<%= post.id %>" method="POST" data-id="<%= post.id %>" onsubmit="return confirmDelete(this.dataset.id)">
              <button type="submit" class="btn btn-warning mb-2 delete_post" role="button" title="Delete Post">Delete</button>
            </form>
          </div>
        </div>
    </main>

    <script>
      const confirmEdit   = (id) => confirm(`Save changes to post #${id}?`);
      const confirmDelete = (id) => confirm(`Delete post #${id}? This cannot be undone.`);
    </script>

